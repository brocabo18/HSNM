# HSNM Environment Variables Template
# Copy this to .env for local development (never commit .env to git)

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unified_network_inventory
DB_USER=postgres
DB_PASS=your_password_here

# --- App ---
APP_ENV=production
APP_NAME=HSNM

# On Railway, these are set automatically via the Railway dashboard or
# linked PostgreSQL service (DATABASE_URL is provided automatically).
